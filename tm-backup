#!/data/data/com.termux/files/usr/bin/bash
# ============================================================
#  tm-backup — Termux 環境備份 / 還原 / 新機安裝 選單
#  版本：1.0  更新：2026-04-14
# ============================================================

# ── 色彩 ────────────────────────────────────────────────────
GREEN='\033[0;32m'; BLUE='\033[0;34m'; YELLOW='\033[1;33m'
RED='\033[0;31m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

# ── 路徑設定 ────────────────────────────────────────────────
TERMUX_HOME="/data/data/com.termux/files/home"
BACKUP_ROOT="/sdcard/Download/termux-backup"
PROOT_BUN="/root/.bun/bin/bun"
CLAUDE_MEM_PLUGIN="$TERMUX_HOME/.claude/plugins/marketplaces/thedotmack/plugin/scripts/worker-service.cjs"

# ── 工具函式 ────────────────────────────────────────────────
info()    { echo -e "${CYAN}[INFO]${NC} $1"; }
ok()      { echo -e "${GREEN}[✅ OK]${NC} $1"; }
warn()    { echo -e "${YELLOW}[⚠️  WARN]${NC} $1"; }
err()     { echo -e "${RED}[❌ ERR]${NC} $1"; }
header()  { echo -e "\n${BOLD}${BLUE}══ $1 ══${NC}"; }
divider() { echo -e "${BLUE}────────────────────────────────────────${NC}"; }

pause() {
    echo ""
    read -r -p "$(echo -e "${YELLOW}按 Enter 繼續...${NC}")" _
}

confirm() {
    # $1 = 問題文字，回傳 0=yes 1=no
    read -r -p "$(echo -e "${YELLOW}$1 [y/N]: ${NC}")" ans
    [[ "$ans" =~ ^[Yy]$ ]]
}

proot_run() {
    proot-distro login ubuntu -- bash -c "$1" 2>/dev/null
}

# ── 狀態檢查 ────────────────────────────────────────────────
check_status() {
    header "目前系統狀態"

    # tmux sessions
    echo -e "${BOLD}[ tmux sessions ]${NC}"
    tmux list-sessions 2>/dev/null || echo "  無 tmux session"

    # claude-mem worker
    echo -e "\n${BOLD}[ claude-mem worker ]${NC}"
    if curl -s http://localhost:37777/health >/dev/null 2>&1; then
        ok "worker 運行中 (port 37777)"
        COUNT=$(proot_run "sqlite3 /root/.claude-mem/claude-mem.db 'SELECT COUNT(*) FROM observations;'" 2>/dev/null)
        info "記憶筆數：${COUNT:-0} observations"
    else
        warn "worker 未運行"
    fi

    # hermes
    echo -e "\n${BOLD}[ Hermes Gateway ]${NC}"
    if tmux has-session -t hermes 2>/dev/null; then
        ok "hermes gateway 運行中"
    else
        warn "hermes gateway 未運行"
    fi

    # 記憶體
    echo -e "\n${BOLD}[ 記憶體 ]${NC}"
    free -h | grep -E "Mem|Swap"

    # 磁碟
    echo -e "\n${BOLD}[ 磁碟空間 ]${NC}"
    df -h "$TERMUX_HOME" | tail -1 | awk '{print "  Termux home: 已用 "$3" / 共 "$2" (使用率 "$5")"}'
    df -h /sdcard/Download 2>/dev/null | tail -1 | awk '{print "  Downloads:   已用 "$3" / 共 "$2" (使用率 "$5")"}'

    # 現有備份
    echo -e "\n${BOLD}[ 現有備份 ]${NC}"
    if ls -d "${BACKUP_ROOT}"-* 2>/dev/null | head -5 | grep -q .; then
        ls -dt "${BACKUP_ROOT}"-* 2>/dev/null | while read -r d; do
            SIZE=$(du -sh "$d" 2>/dev/null | cut -f1)
            DATE=$(basename "$d" | sed 's/termux-backup-//')
            echo "  📦 $DATE  ($SIZE)"
        done
    else
        info "尚無備份"
    fi
    pause
}

# ── 備份 ────────────────────────────────────────────────────
do_backup() {
    local MODE="$1"   # quick | full
    local BACKUP_DATE
    BACKUP_DATE=$(date +%Y%m%d_%H%M)
    local DEST="${BACKUP_ROOT}-${BACKUP_DATE}"

    header "開始備份 (${MODE^^})"
    info "目標目錄：$DEST"
    mkdir -p "$DEST"

    local ERRORS=0

    _pack() {
        local label="$1" src="$2" out="$3"
        echo -ne "  打包 ${label}... "
        if [ -e "$src" ]; then
            tar czf "$DEST/$out" -C "$TERMUX_HOME" "$src" 2>/dev/null
            ok "完成 ($(du -sh "$DEST/$out" 2>/dev/null | cut -f1))"
        else
            warn "不存在，跳過"
            ((ERRORS++))
        fi
    }

    # ── 必備項目 ─────────────────────────────────────
    echo -e "\n${BOLD}必備項目：${NC}"
    _pack ".bashrc"    .bashrc       bashrc.tar.gz
    _pack ".hermes"    .hermes       hermes.tar.gz
    _pack ".claude"    .claude       claude.tar.gz
    _pack "claude-mem" claude-mem    claude-mem.tar.gz

    # ── 選備項目（full 模式）──────────────────────────
    if [ "$MODE" = "full" ]; then
        echo -e "\n${BOLD}選備項目（full 模式）：${NC}"
        _pack "bin/"       bin           bin.tar.gz
        _pack "ClawTeam"   ClawTeam-OpenClaw clawteam.tar.gz 2>/dev/null || true
    fi

    # ── 備份清單 ─────────────────────────────────────
    {
        echo "backup_date=$BACKUP_DATE"
        echo "backup_mode=$MODE"
        echo "termux_home=$TERMUX_HOME"
        echo "files=$(ls "$DEST"/*.tar.gz 2>/dev/null | xargs -I{} basename {} | tr '\n' ',')"
    } > "$DEST/backup.info"

    divider
    ok "備份完成：$DEST"
    echo ""
    ls -lh "$DEST"
    echo ""

    # 只保留最近 5 份
    KEEP=5
    COUNT=$(ls -dt "${BACKUP_ROOT}"-* 2>/dev/null | wc -l)
    if [ "$COUNT" -gt "$KEEP" ]; then
        info "清理舊備份（保留最近 $KEEP 份）..."
        ls -dt "${BACKUP_ROOT}"-* 2>/dev/null | tail -n +$((KEEP+1)) | while read -r d; do
            rm -rf "$d"
            info "已刪除：$(basename "$d")"
        done
    fi

    [ "$ERRORS" -gt 0 ] && warn "有 $ERRORS 個項目跳過" || ok "全部項目備份成功"
    pause
}

# ── 選擇備份 ────────────────────────────────────────────────
select_backup() {
    header "選擇備份版本"
    local backups=()
    while IFS= read -r d; do
        backups+=("$d")
    done < <(ls -dt "${BACKUP_ROOT}"-* 2>/dev/null)

    if [ ${#backups[@]} -eq 0 ]; then
        err "找不到任何備份（路徑：${BACKUP_ROOT}-*）"
        pause
        return 1
    fi

    echo ""
    for i in "${!backups[@]}"; do
        SIZE=$(du -sh "${backups[$i]}" 2>/dev/null | cut -f1)
        DATE=$(basename "${backups[$i]}" | sed 's/termux-backup-//')
        echo -e "  ${BOLD}$((i+1))${NC}. 📦 $DATE  ($SIZE)"
    done
    echo -e "  ${BOLD}0${NC}. 取消"
    echo ""

    read -r -p "$(echo -e "${YELLOW}選擇備份 [0-${#backups[@]}]: ${NC}")" SEL
    [[ "$SEL" == "0" || -z "$SEL" ]] && return 1
    [[ "$SEL" -ge 1 && "$SEL" -le ${#backups[@]} ]] || { err "無效選項"; return 1; }

    SELECTED_BACKUP="${backups[$((SEL-1))]}"
    return 0
}

# ── 還原 ────────────────────────────────────────────────────
do_restore() {
    header "還原備份"

    select_backup || { pause; return; }

    info "選擇備份：$(basename "$SELECTED_BACKUP")"
    echo ""

    # 顯示備份內容
    if [ -f "$SELECTED_BACKUP/backup.info" ]; then
        echo -e "${BOLD}備份資訊：${NC}"
        grep -v "^#" "$SELECTED_BACKUP/backup.info" | while IFS='=' read -r k v; do
            echo "  $k: $v"
        done
        echo ""
    fi

    ls -lh "$SELECTED_BACKUP"/*.tar.gz 2>/dev/null
    echo ""

    confirm "確認還原？（會覆蓋現有設定）" || { info "取消還原"; pause; return; }

    echo ""
    local ERRORS=0

    _unpack() {
        local label="$1" file="$2"
        echo -ne "  還原 ${label}... "
        if [ -f "$SELECTED_BACKUP/$file" ]; then
            tar xzf "$SELECTED_BACKUP/$file" -C "$TERMUX_HOME" 2>/dev/null
            ok "完成"
        else
            warn "找不到 $file，跳過"
            ((ERRORS++))
        fi
    }

    _unpack "bashrc"    bashrc.tar.gz
    _unpack "hermes"    hermes.tar.gz
    _unpack "claude"    claude.tar.gz
    _unpack "claude-mem" claude-mem.tar.gz
    _unpack "bin"       bin.tar.gz
    _unpack "ClawTeam"  clawteam.tar.gz

    divider
    [ "$ERRORS" -gt 0 ] && warn "有 $ERRORS 個項目跳過" || ok "還原完成"
    echo ""
    info "請繼續執行「新機安裝設定」完成 proot/symlink/服務啟動"
    pause
}

# ── 新機安裝 ────────────────────────────────────────────────
do_fresh_install() {
    header "新機安裝設定精靈"
    echo -e "${YELLOW}此步驟會依序完成所有服務的安裝與設定。${NC}"
    echo -e "${YELLOW}假設你已完成「還原備份」或手動放好設定檔。${NC}\n"
    confirm "開始安裝流程？" || { pause; return; }

    local STEP=0
    _step() { ((STEP++)); echo -e "\n${BOLD}${BLUE}[Step $STEP] $1${NC}"; }

    # Step 1: 套件更新
    _step "更新 Termux 套件"
    pkg update -y 2>&1 | tail -3
    ok "套件更新完成"

    # Step 2: 安裝必要套件
    _step "安裝必要套件"
    pkg install -y openssh git python nodejs tmux proot-distro curl wget 2>&1 | tail -3
    ok "套件安裝完成"

    # Step 3: 儲存權限
    _step "設定儲存空間權限"
    if [ -d "/sdcard/Download" ]; then
        ok "已有儲存空間權限"
    else
        info "正在請求儲存空間權限..."
        termux-setup-storage
        sleep 2
    fi

    # Step 4: Wake lock
    _step "設定 Wake Lock（防止系統積極換頁）"
    termux-wake-lock 2>/dev/null && ok "Wake lock 已啟用" || warn "Wake lock 設定失敗（可忽略）"

    # Step 5: proot ubuntu
    _step "安裝 proot-distro Ubuntu"
    if proot_run "echo ok" 2>/dev/null | grep -q ok; then
        ok "Ubuntu 已安裝"
    else
        info "正在安裝 Ubuntu..."
        proot-distro install ubuntu
        ok "Ubuntu 安裝完成"
    fi

    # Step 6: Bun
    _step "在 proot Ubuntu 安裝 Bun"
    if proot_run "/root/.bun/bin/bun --version" 2>/dev/null | grep -qE "^[0-9]"; then
        ok "Bun 已安裝 ($(proot_run '/root/.bun/bin/bun --version' 2>/dev/null))"
    else
        info "正在安裝 Bun..."
        proot_run "curl -fsSL https://bun.sh/install | bash" 2>&1 | tail -3
        if proot_run "/root/.bun/bin/bun --version" 2>/dev/null | grep -qE "^[0-9]"; then
            ok "Bun 安裝完成"
        else
            err "Bun 安裝失敗，請手動安裝"
        fi
    fi

    # Step 7: claude-mem symlink
    _step "建立 claude-mem symlink（proot → Termux home）"
    if [ -d "$TERMUX_HOME/claude-mem" ]; then
        proot_run "rm -f /root/.claude-mem && ln -sf /data/data/com.termux/files/home/claude-mem /root/.claude-mem"
        ok "symlink 建立完成"
        info "$(proot_run 'ls -la /root/.claude-mem' 2>/dev/null | head -1)"
    else
        warn "~/claude-mem 不存在，請先還原備份或初次執行 claude-mem"
        proot_run "mkdir -p /root/.claude-mem" 2>/dev/null
    fi

    # Step 8: 安裝 Claude Code
    _step "安裝 Claude Code"
    if command -v claude >/dev/null 2>&1; then
        ok "Claude Code 已安裝 ($(claude --version 2>/dev/null | head -1))"
    else
        info "正在安裝 Claude Code..."
        npm install -g @anthropic-ai/claude-code 2>&1 | tail -3
        ok "Claude Code 安裝完成"
    fi

    # Step 9: 安裝 claude-mem plugin
    _step "安裝 claude-mem plugin"
    if [ -f "$CLAUDE_MEM_PLUGIN" ]; then
        ok "claude-mem plugin 已存在"
    else
        info "正在安裝 claude-mem..."
        npx claude-mem install 2>&1 | tail -5
        ok "claude-mem plugin 安裝完成"
    fi

    # Step 10: 啟動 claude-mem worker
    _step "啟動 claude-mem worker"
    if curl -s http://localhost:37777/health >/dev/null 2>&1; then
        ok "worker 已在運行"
    else
        tmux new-session -d -s claude-mem \
            "proot-distro login ubuntu -- $PROOT_BUN run '$CLAUDE_MEM_PLUGIN'" 2>/dev/null
        sleep 4
        if curl -s http://localhost:37777/health >/dev/null 2>&1; then
            ok "claude-mem worker 啟動成功"
        else
            err "worker 啟動失敗，請手動執行：CM"
        fi
    fi

    # Step 11: 啟動 Hermes Gateway
    _step "啟動 Hermes Gateway"
    if tmux has-session -t hermes 2>/dev/null; then
        ok "hermes 已在運行"
    else
        if command -v hermes >/dev/null 2>&1; then
            tmux new-session -d -s hermes "hermes gateway run" 2>/dev/null
            sleep 3
            ok "Hermes Gateway 啟動完成"
        else
            warn "hermes 指令不存在，請確認安裝狀態"
        fi
    fi

    # Step 12: 驗證
    _step "最終驗證"
    divider
    echo -e "${BOLD}服務狀態：${NC}"
    tmux has-session -t hermes 2>/dev/null && ok "Hermes Gateway" || warn "Hermes Gateway 未啟動"
    curl -s http://localhost:37777/health >/dev/null 2>&1 && ok "claude-mem worker" || warn "claude-mem worker 未啟動"
    command -v claude >/dev/null && ok "Claude Code" || warn "Claude Code 未安裝"
    command -v hermes >/dev/null && ok "Hermes CLI" || warn "Hermes CLI 未安裝"
    proot_run "ls /root/.claude-mem/claude-mem.db" >/dev/null 2>&1 && ok "claude-mem DB 存在" || warn "claude-mem DB 不存在"
    divider
    echo ""
    ok "新機安裝完成！"
    info "最後請執行：source ~/.bashrc"
    pause
}

# ── 刪除舊備份 ───────────────────────────────────────────────
do_delete_backup() {
    header "刪除備份"

    select_backup || { pause; return; }

    warn "即將刪除：$(basename "$SELECTED_BACKUP")"
    ls -lh "$SELECTED_BACKUP" 2>/dev/null

    confirm "確定刪除？（不可恢復）" || { info "取消"; pause; return; }

    rm -rf "$SELECTED_BACKUP"
    ok "已刪除：$(basename "$SELECTED_BACKUP")"
    pause
}

# ── 主選單 ───────────────────────────────────────────────────
main_menu() {
    while true; do
        clear
        echo -e "${BOLD}${BLUE}"
        echo "  ╔══════════════════════════════════════╗"
        echo "  ║     Termux 備份 & 還原 管理工具      ║"
        echo "  ╚══════════════════════════════════════╝"
        echo -e "${NC}"

        echo -e "  ${BOLD}── 備份（舊機執行）──────────────────${NC}"
        echo -e "  ${GREEN}1${NC}. 完整備份（.bashrc .hermes .claude claude-mem ClawTeam bin）"
        echo ""
        echo -e "  ${BOLD}── 新機換機（依序執行）──────────────${NC}"
        echo -e "  ${CYAN}2${NC}. 【第一步】新機安裝設定精靈（裝軟體/環境，先跑這個）"
        echo -e "  ${CYAN}3${NC}. 【第二步】從備份還原設定檔（蓋回舊設定，精靈跑完後選）"
        echo ""
        echo -e "  ${BOLD}── 管理 ──────────────────────────────${NC}"
        echo -e "  ${YELLOW}4${NC}. 查看系統狀態"
        echo -e "  ${YELLOW}5${NC}. 刪除舊備份"
        echo ""
        echo -e "  ${RED}0${NC}. 離開"
        echo ""

        # 顯示最新備份時間
        LATEST=$(ls -dt "${BACKUP_ROOT}"-* 2>/dev/null | head -1)
        if [ -n "$LATEST" ]; then
            echo -e "  ${BLUE}最新備份：$(basename "$LATEST" | sed 's/termux-backup-//')${NC}"
        else
            echo -e "  ${YELLOW}尚無備份${NC}"
        fi
        echo ""

        read -r -p "$(echo -e "${BOLD}選擇 [0-5]: ${NC}")" CHOICE

        case "$CHOICE" in
            1) do_backup full ;;
            2) do_fresh_install ;;
            3) do_restore ;;
            4) check_status ;;
            5) do_delete_backup ;;
            0) echo -e "\n${GREEN}掰掰！${NC}\n"; exit 0 ;;
            *) warn "無效選項，請輸入 0–5"; sleep 1 ;;
        esac
    done
}

# ── 進入點 ───────────────────────────────────────────────────
main_menu
